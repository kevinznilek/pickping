# Database
DATABASE_URL="postgresql://username:password@localhost:5432/pickleup"

# NextAuth.js
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-secret-key-here"

# Twilio
TWILIO_ACCOUNT_SID="your-twilio-account-sid"
TWILIO_AUTH_TOKEN="your-twilio-auth-token"
TWILIO_PHONE_NUMBER="+1234567890"

# App Configuration
CONFIRM_DEADLINE_HOURS="48"
ROSTER_LOCK_HOURS="24"

# Google OAuth (for Gmail integration)
# Create credentials at https://console.cloud.google.com/apis/credentials
# Add http://localhost:3000/api/auth/gmail/callback as an Authorized redirect URI
GOOGLE_CLIENT_ID="your-google-client-id-here"
GOOGLE_CLIENT_SECRET="your-google-client-secret-here"
# Optional: override the redirect URI (defaults to ${NEXTAUTH_URL}/api/auth/gmail/callback)
# GOOGLE_REDIRECT_URI="http://localhost:3000/api/auth/gmail/callback"